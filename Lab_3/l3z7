#include <stdio.h>
#include <signal.h>
#include <stdlib.h>
#include <unistd.h>

void handler(int sig) {
    if (sig == SIGXCPU) {
        fprintf(stderr, "Received SIGXCPU (CPU time limit reached)\n");
        _exit(1);
    }
}
int main(void) {
    struct sigaction sa;
    sa.sa_handler = handler;
    sa.sa_flags = 0;
    sigemptyset(&sa.sa_mask);
    sigaction(SIGXCPU, &sa, NULL);

    while (1) { }
    return 0;
}