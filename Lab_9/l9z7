#include <stdio.h>
#include <stdlib.h>
#include <fcntl.h>
#include <unistd.h>
#include <errno.h>
#include <string.h>
#include <sys/stat.h>

#define FILENAME "writeonly.txt"

int main() {
    int fd = open(FILENAME, O_WRONLY | O_CREAT | O_TRUNC, 0200);
    if (fd == -1) {
        perror("open create");
        exit(EXIT_FAILURE);
    }
    close(fd);
    printf("Файл '%s' створено з правами 0200 (--w-------)\n", FILENAME);

    fd = open(FILENAME, O_RDONLY);
    if (fd == -1) {
        printf("Читання: %s (очікувана помилка)\n", strerror(errno));
    } else {
        char buf[10];
        ssize_t n = read(fd, buf, sizeof(buf));
        if (n == -1) perror("read failed");
        else printf("Прочитано %zd байтів (не мало б статися)\n", n);
        close(fd);
    }

    fd = open(FILENAME, O_WRONLY);
    if (fd == -1) {
        perror("open write");
        exit(EXIT_FAILURE);
    }
    const char *msg = "Це тестовий запис.\n";
    ssize_t written = write(fd, msg, strlen(msg));
    if (written == -1)
        perror("write failed");
    else
        printf("Запис успішний: %zd байтів\n", written);
    close(fd);

    struct stat st;
    if (stat(FILENAME, &st) == 0) {
        printf("Права файлу: %o\n", st.st_mode & 0777);
    }

    return 0;
}