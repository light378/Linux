#include <stdio.h>
#include <stdlib.h>
#include <time.h>

unsigned long long cmp_count = 0;

int cmp_int(const void *a, const void *b) {
    cmp_count++;
    int x = *(const int *)a;
    int y = *(const int *)b;
    if (x < y) return -1;
    if (x > y) return 1;
    return 0;
}

int is_sorted(int *a, int n) {
    for (int i = 1; i < n; i++) {
        if (a[i - 1] > a[i]) return 0;
    }
    return 1;
}

void run_test(const char *name, int *src, int n) {
    int *a = malloc(n * sizeof(int));
    for (int i = 0; i < n; i++) a[i] = src[i];

    qsort(a, n, sizeof(int), cmp_int);

    if (is_sorted(a, n))
        printf("ТЕСТ %s: УСПІХ\n", name);
    else
        printf("ТЕСТ %s: ПОМИЛКА\n", name);

    free(a);
}

double now_ms(void) {
    struct timespec ts;
    clock_gettime(CLOCK_MONOTONIC, &ts);
    return ts.tv_sec * 1000.0 + ts.tv_nsec / 1000000.0;
}

void fill_array(int *a, int n, int type) {
    if (type == 0) {
        for (int i = 0; i < n; i++) a[i] = rand();
    } else if (type == 1) {
        for (int i = 0; i < n; i++) a[i] = i;
    } else if (type == 2) {
        for (int i = 0; i < n; i++) a[i] = n - i;
    } else if (type == 3) {
        for (int i = 0; i < n; i++) a[i] = 7;
    }
}

const char *name_type(int type) {
    if (type == 0) return "випадковий";
    if (type == 1) return "вже відсортований";
    if (type == 2) return "зворотний";
    return "усі однакові";
}

int main(void) {
    srand(1);

    int t1[] = {5, 1, 4, 2, 3};
    int t2[] = {1, 2, 3, 4, 5};
    int t3[] = {5, 4, 3, 2, 1};
    int t4[] = {3, 3, 3, 3, 3};

    printf("=== Перевірка qsort ===\n");
    run_test("змішаний", t1, 5);
    run_test("відсортований", t2, 5);
    run_test("зворотний", t3, 5);
    run_test("однакові", t4, 5);

    printf("\n=== Експеримент ===\n");

    int n = 50000;
    int repeats = 3;
    int *a = malloc(n * sizeof(int));

    double best_cmp = -1.0;
    int worst_type = -1;

    for (int type = 0; type < 4; type++) {
        double sum_cmp = 0.0;
        double sum_time = 0.0;

        for (int r = 0; r < repeats; r++) {
            fill_array(a, n, type);

            cmp_count = 0;
            double t1m = now_ms();
            qsort(a, n, sizeof(int), cmp_int);
            double t2m = now_ms();

            sum_cmp += (double)cmp_count;
            sum_time += (t2m - t1m);
        }

        double avg_cmp = sum_cmp / repeats;
        double avg_time = sum_time / repeats;

        printf("%s: середні_порівняння=%.0f середній_час=%.3f мс\n",
               name_type(type), avg_cmp, avg_time);

        if (avg_cmp > best_cmp) {
            best_cmp = avg_cmp;
            worst_type = type;
        }
    }

    printf("Найповільніший тип для цього qsort: %s\n", name_type(worst_type));

    free(a);
    return 0;
}
